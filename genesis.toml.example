# genesis-rs configuration
# Customize package lists per platform.
# If this file is absent, built-in defaults are used.
#
# Usage:
#   genesis-rs bootstrap                        # auto-loads genesis.toml if present
#   genesis-rs --config custom.toml bootstrap   # explicit config path
#
# Merge behavior:
#   The final package list = common + platform-specific.
#   Example on Debian: common + debian packages are installed.

[packages]
# Packages installed on ALL platforms (default: ["git", "curl", "vim", "htop"])
common = ["git", "curl", "vim", "htop"]

# Additional packages for Debian only
debian = []

# Additional packages for Arch Linux only
arch = []

# Additional packages for Raspberry Pi OS only
raspbian = []
